// CoWork HQ — Prisma Schema
// Stack: PostgreSQL via Supabase · Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  STAFF
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
  RESCHEDULED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum PaymentMethod {
  UPI
  CARD
  WALLET
  NET_BANKING
}

enum PricingType {
  HOURLY
  DAILY
  MONTHLY
  WEEKLY
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

enum WorkspaceStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

// ─────────────────────────────────────────────
// USER (all roles share this table)
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String?  @unique
  passwordHash  String
  name          String
  role          Role
  isActive      Boolean  @default(true)
  isBanned      Boolean  @default(false)
  bannedReason  String?
  bannedAt      DateTime?
  bannedBy      String?  // Admin user id
  profileImage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  managerProfile  Manager?
  staffProfile    Staff?
  customerProfile Customer?
  adminProfile    Admin?

  // Issued bans (admin banning others)
  bansIssued      User[]   @relation("BannedBy")
  bannedByUser    User?    @relation("BannedBy", fields: [bannedBy], references: [id])

  sessions        Session[]
  notifications   Notification[]

  @@map("users")
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  deviceInfo String?
  ipAddress  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─────────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────────

model Admin {
  id          String   @id @default(uuid())
  userId      String   @unique
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ─────────────────────────────────────────────
// MANAGER (Workspace Owner)
// ─────────────────────────────────────────────

model Manager {
  id                String   @id @default(uuid())
  userId            String   @unique
  businessName      String
  gstNumber         String?
  panNumber         String?
  bankAccountNumber String?
  bankIfsc          String?
  platformFeeDue    Decimal  @default(0) @db.Decimal(10,2)
  totalPaid         Decimal  @default(0) @db.Decimal(10,2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaces  Workspace[]
  staffCodes  StaffCode[]
  staff       Staff[]
  payments    PlatformFeePayment[]
  feedbacks   ManagerFeedback[]

  @@map("managers")
}

// ─────────────────────────────────────────────
// STAFF
// ─────────────────────────────────────────────

model StaffCode {
  id         String    @id @default(uuid())
  managerId  String
  code       String    @unique  // 8-char alphanumeric code staff uses to connect
  isUsed     Boolean   @default(false)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  manager Manager @relation(fields: [managerId], references: [id], onDelete: Cascade)
  staff   Staff?

  @@map("staff_codes")
}

model Staff {
  id          String   @id @default(uuid())
  userId      String   @unique
  managerId   String
  staffCodeId String   @unique
  workspaceId String?  // assigned workspace
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  manager     Manager       @relation(fields: [managerId], references: [id])
  staffCode   StaffCode     @relation(fields: [staffCodeId], references: [id])
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id])
  issueAssignments IssueAssignment[]

  @@map("staff")
}

// ─────────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────────

model Customer {
  id              String   @id @default(uuid())
  userId          String   @unique
  loyaltyPoints   Int      @default(0)
  referralCode    String   @unique @default(cuid())
  referredBy      String?
  preferredLang   String   @default("en")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  feedbacks Feedback[]
  warnings  CustomerWarning[]

  @@map("customers")
}

model CustomerWarning {
  id          String   @id @default(uuid())
  customerId  String
  issuedBy    String   // Manager userId
  reason      String
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_warnings")
}

// ─────────────────────────────────────────────
// WORKSPACE
// ─────────────────────────────────────────────

model Workspace {
  id           String          @id @default(uuid())
  managerId    String
  name         String
  description  String?
  address      String
  city         String
  state        String
  pincode      String
  latitude     Decimal         @db.Decimal(10, 7)
  longitude    Decimal         @db.Decimal(10, 7)
  googleMapsUrl String?
  status       WorkspaceStatus @default(ACTIVE)
  amenities    String[]        @default([])  // wifi, parking, cafeteria, etc.
  images       WorkspaceImage[]
  totalDesks   Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  manager      Manager          @relation(fields: [managerId], references: [id], onDelete: Cascade)
  desks        Desk[]
  staff        Staff[]
  pricingPlans PricingPlan[]
  workingHours WorkingHours[]
  coupons      Coupon[]
  qrCodes      QrCode[]
  bookings     Booking[]
  feedbacks    Feedback[]

  @@map("workspaces")
}

model WorkspaceImage {
  id          String   @id @default(uuid())
  workspaceId String
  url         String
  order       Int      @default(0)  // display order (max 4)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_images")
}

model WorkingHours {
  id          String    @id @default(uuid())
  workspaceId String
  day         DayOfWeek
  openTime    String    // "09:00"
  closeTime   String    // "21:00"
  isClosed    Boolean   @default(false)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, day])
  @@map("working_hours")
}

// ─────────────────────────────────────────────
// DESK
// ─────────────────────────────────────────────

model Desk {
  id           String   @id @default(uuid())
  workspaceId  String
  deskNumber   String   // e.g. "A1", "B3"
  type         String   @default("standard")  // standard, window, private, cabin
  description  String?
  isActive     Boolean  @default(true)
  premiumExtra Decimal  @default(0) @db.Decimal(8,2) // extra charge e.g. ₹100 for window
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bookings  Booking[]
  qrCodes   QrCode[]

  @@unique([workspaceId, deskNumber])
  @@map("desks")
}

// ─────────────────────────────────────────────
// PRICING PLANS
// ─────────────────────────────────────────────

model PricingPlan {
  id          String      @id @default(uuid())
  workspaceId String
  name        String      // "Day Pass", "Monthly Hot Desk"
  type        PricingType
  basePrice   Decimal     @db.Decimal(10,2)  // e.g. ₹199 per day
  currency    String      @default("INR")
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@map("pricing_plans")
}

// ─────────────────────────────────────────────
// COUPON
// ─────────────────────────────────────────────

model Coupon {
  id              String    @id @default(uuid())
  workspaceId     String
  code            String    @unique
  discountPercent Decimal?  @db.Decimal(5,2)
  discountFlat    Decimal?  @db.Decimal(10,2)
  maxUses         Int       @default(100)
  usedCount       Int       @default(0)
  validFrom       DateTime
  validUntil      DateTime
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@map("coupons")
}

// ─────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(uuid())
  customerId      String
  workspaceId     String
  deskId          String
  pricingPlanId   String
  couponId        String?
  status          BookingStatus @default(PENDING)
  startTime       DateTime
  endTime         DateTime
  checkInTime     DateTime?
  checkOutTime    DateTime?
  baseAmount      Decimal       @db.Decimal(10,2)
  discountAmount  Decimal       @default(0) @db.Decimal(10,2)
  premiumExtra    Decimal       @default(0) @db.Decimal(10,2)
  totalAmount     Decimal       @db.Decimal(10,2)
  gstAmount       Decimal       @db.Decimal(10,2)  // 18%
  finalAmount     Decimal       @db.Decimal(10,2)
  rejectedReason  String?
  // Reschedule tracking
  isRescheduled   Boolean       @default(false)
  originalBookingId String?     // if this is a rescheduled booking
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer    Customer    @relation(fields: [customerId], references: [id])
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  desk        Desk        @relation(fields: [deskId], references: [id])
  pricingPlan PricingPlan @relation(fields: [pricingPlanId], references: [id])
  coupon      Coupon?     @relation(fields: [couponId], references: [id])

  payment     Payment?
  invoice     Invoice?

  @@map("bookings")
}

// ─────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────

model Payment {
  id                String        @id @default(uuid())
  bookingId         String        @unique
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  amount            Decimal       @db.Decimal(10,2)
  currency          String        @default("INR")
  method            PaymentMethod @default(UPI)
  status            PaymentStatus @default(PENDING)
  refundId          String?
  refundAmount      Decimal?      @db.Decimal(10,2)
  refundStatus      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  booking  Booking  @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model Invoice {
  id            String   @id @default(uuid())
  bookingId     String   @unique
  invoiceNumber String   @unique
  gstNumber     String?  // workspace owner's GST
  issuedAt      DateTime @default(now())
  pdfUrl        String?

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("invoices")
}

// ─────────────────────────────────────────────
// PLATFORM FEE (Manager → Admin)
// ─────────────────────────────────────────────

model PlatformFeePayment {
  id              String        @id @default(uuid())
  managerId       String
  amount          Decimal       @db.Decimal(10,2)
  month           String        // "2026-05"
  razorpayOrderId String        @unique
  razorpayPaymentId String?     @unique
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())

  manager Manager @relation(fields: [managerId], references: [id])

  @@map("platform_fee_payments")
}

// ─────────────────────────────────────────────
// QR CODE (desk-level, for customer issue reports)
// ─────────────────────────────────────────────

model QrCode {
  id          String   @id @default(uuid())
  workspaceId String
  deskId      String?  // null = workspace-level QR
  code        String   @unique @default(cuid())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  desk      Desk?     @relation(fields: [deskId], references: [id])
  issues    Issue[]

  @@map("qr_codes")
}

// ─────────────────────────────────────────────
// ISSUE (raised via QR scan or customer app)
// ─────────────────────────────────────────────

model Issue {
  id          String      @id @default(uuid())
  qrCodeId    String?
  workspaceId String      // redundant for easy querying
  deskId      String?
  reportedBy  String?     // customerId (null if scanned without login)
  description String
  status      IssueStatus @default(OPEN)
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  qrCode      QrCode?          @relation(fields: [qrCodeId], references: [id])
  assignments IssueAssignment[]

  @@map("issues")
}

model IssueAssignment {
  id         String    @id @default(uuid())
  issueId    String
  staffId    String
  assignedAt DateTime  @default(now())
  resolvedAt DateTime?
  note       String?   // staff resolution note

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  staff Staff @relation(fields: [staffId], references: [id])

  @@map("issue_assignments")
}

// ─────────────────────────────────────────────
// FEEDBACK
// ─────────────────────────────────────────────

model Feedback {
  id          String   @id @default(uuid())
  customerId  String
  workspaceId String
  bookingId   String?
  rating      Int      // 1–5
  comment     String?
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  customer  Customer  @relation(fields: [customerId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("feedbacks")
}

model ManagerFeedback {
  id         String   @id @default(uuid())
  managerId  String
  subject    String
  message    String
  isResolved Boolean  @default(false)
  adminNote  String?
  createdAt  DateTime @default(now())

  manager Manager @relation(fields: [managerId], references: [id])

  @@map("manager_feedbacks")
}

// ─────────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   // booking_confirmed, issue_resolved, payment_success etc.
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
