# ──────────────────────────────────────────────
# CoWork HQ — Environment Variables
# Copy this to .env and fill in your values
# ──────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis (for caching & sessions)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# WhatsApp (WATI / Interakt)
WHATSAPP_API_URL=https://live-mt-server.wati.io/api
WHATSAPP_API_TOKEN=your-wati-token

# Supabase Storage (for images)
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_STORAGE_BUCKET=coworkhq-images

# GST
GST_RATE=0.18

# Platform Fee (monthly, per workspace, in INR)
PLATFORM_FEE_PER_WORKSPACE=999

# Refund Policy
CANCELLATION_REFUND_PERCENT=85

# Admin account (seed)
ADMIN_EMAIL=admin@coworkhq.in
ADMIN_PASSWORD=ChangeThisPassword123!
ADMIN_NAME=CoWork HQ Admin
