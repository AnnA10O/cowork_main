# ──────────────────────────────────────────────
# CoWork HQ — Environment Variables
# ──────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Session-mode pooler — supports prisma db push + works on free tier
DATABASE_URL=postgresql://postgres.ocqidukwxyberwtxorzn:co-work_space@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# JWT — generated secure secret (do NOT share publicly)
JWT_SECRET=cwhq-jwt-secret-8f3a9b2e1d4c7f6a0e5b8d2c9f1a3e7b
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis — optional, can leave blank for development
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ⚠️  FILL IN: Razorpay keys (payment endpoints won't work until filled)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# WhatsApp (WATI) — optional, silently skipped if blank
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# Supabase Storage — for workspace image uploads
SUPABASE_URL=https://[YOUR_PROJECT].supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
SUPABASE_STORAGE_BUCKET=coworkhq-images

# Business rules
GST_RATE=0.18
PLATFORM_FEE_PER_WORKSPACE=999
CANCELLATION_REFUND_PERCENT=85

# Admin seed account
ADMIN_EMAIL=admin@coworkhq.in
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=CoWork HQ Admin

# CORS — comma separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200,http://localhost:8080
